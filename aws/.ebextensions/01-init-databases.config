option_settings:
  aws:elasticbeanstalk:application:environment:
    POSTGRES_PORT: "5432"

# Run an init container once on first deploy that creates the per-service databases
# in RDS using POSTGRES_USER/POSTGRES_PASSWORD. Skips if they already exist.
container_commands:
  01-init-databases:
    command: |
      docker run --rm \
        -e POSTGRES_HOST="$POSTGRES_HOST" \
        -e POSTGRES_USER="$POSTGRES_USER" \
        -e POSTGRES_PASSWORD="$POSTGRES_PASSWORD" \
        postgres:16-alpine sh -c '
          for db in productdb inventorydb paymentdb orderdb notificationdb sellerdb userdb; do
            user=$(echo "$db" | sed "s/db$//")
            export PGPASSWORD="$POSTGRES_PASSWORD"
            psql -h "$POSTGRES_HOST" -U "$POSTGRES_USER" -d postgres -tc "SELECT 1 FROM pg_database WHERE datname='\''$db'\''" | grep -q 1 || \
              psql -h "$POSTGRES_HOST" -U "$POSTGRES_USER" -d postgres -c "CREATE USER $user WITH PASSWORD '\''pass'\''; CREATE DATABASE $db OWNER $user; GRANT ALL ON DATABASE $db TO $user;"
          done
        ' || true
    leader_only: true
